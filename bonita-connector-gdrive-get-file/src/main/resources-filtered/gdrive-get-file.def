<?xml version="1.0" encoding="UTF-8"?>
<definition:ConnectorDefinition
    xmlns:definition="http://www.bonitasoft.org/ns/connector/definition/6.1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <id>${connector-id.def.id}</id>
    <version>${connector-id.def.version}</version>
    <icon>gdrive.png</icon>

    <category id="GoogleDrive" icon="gdrive.png" parentCategoryId="Cloud"/>

    <!-- === INPUTS === -->
    <!-- Connection (Project/Runtime) -->
    <input name="serviceAccountKeyJson" type="java.lang.String" mandatory="true"/>
    <input name="impersonatedUserEmail" type="java.lang.String" mandatory="false"/>
    <input name="applicationName" type="java.lang.String" mandatory="false" defaultValue="Bonita-GoogleDrive-Connector"/>
    <input name="connectTimeout" type="java.lang.Integer" mandatory="false" defaultValue="30000"/>
    <input name="readTimeout" type="java.lang.Integer" mandatory="false" defaultValue="60000"/>

    <!-- File (Connector) -->
    <input name="fileId" type="java.lang.String" mandatory="true"/>

    <!-- Advanced (Process) -->
    <input name="fields" type="java.lang.String" mandatory="false" defaultValue="id,name,mimeType,webViewLink,webContentLink,size,createdTime,modifiedTime,owners,parents"/>

    <!-- === OUTPUTS === -->
    <output name="fileId" type="java.lang.String"/>
    <output name="fileName" type="java.lang.String"/>
    <output name="mimeType" type="java.lang.String"/>
    <output name="webViewLink" type="java.lang.String"/>
    <output name="webContentLink" type="java.lang.String"/>
    <output name="sizeBytes" type="java.lang.Long"/>
    <output name="createdTime" type="java.lang.String"/>
    <output name="modifiedTime" type="java.lang.String"/>
    <output name="ownerEmail" type="java.lang.String"/>
    <output name="success" type="java.lang.Boolean"/>
    <output name="errorMessage" type="java.lang.String"/>

    <!-- === UI PAGES === -->
    <page id="connectionPage">
        <widget id="serviceAccountKeyJsonWidget" inputName="serviceAccountKeyJson" xsi:type="definition:Password"/>
        <widget id="impersonatedUserEmailWidget" inputName="impersonatedUserEmail" xsi:type="definition:Text"/>
        <widget id="applicationNameWidget" inputName="applicationName" xsi:type="definition:Text"/>
        <widget id="connectTimeoutWidget" inputName="connectTimeout" xsi:type="definition:Text"/>
        <widget id="readTimeoutWidget" inputName="readTimeout" xsi:type="definition:Text"/>
    </page>
    <page id="operationPage">
        <widget id="fileIdWidget" inputName="fileId" xsi:type="definition:Text"/>
    </page>
    <page id="advancedPage">
        <widget id="fieldsWidget" inputName="fields" xsi:type="definition:TextArea"/>
    </page>
</definition:ConnectorDefinition>

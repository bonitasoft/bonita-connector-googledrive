<?xml version="1.0" encoding="UTF-8"?>
<definition:ConnectorDefinition xmlns:definition="http://www.bonitasoft.org/ns/connector/definition/6.1"
                                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <id>${gdrive-upload-file.def.id}</id>
    <version>${gdrive-upload-file.def.version}</version>
    <icon>drive_48dp.png</icon>

    <category icon="drive_48dp.png" id="Google Drive"/>

    <!-- === Page 1 — Connection === -->
    <input name="serviceAccountKeyJson" type="java.lang.String" mandatory="true"/>
    <input name="impersonatedUserEmail" type="java.lang.String" mandatory="false"/>
    <input name="applicationName" type="java.lang.String" mandatory="false" defaultValue="Bonita-GoogleDrive-Connector"/>
    <input name="connectTimeout" type="java.lang.Integer" mandatory="false" defaultValue="30000"/>
    <input name="readTimeout" type="java.lang.Integer" mandatory="false" defaultValue="60000"/>

    <!-- === Page 2 — Upload === -->
    <input name="fileName" type="java.lang.String" mandatory="true"/>
    <input name="fileContentBase64" type="java.lang.String" mandatory="true"/>
    <input name="mimeType" type="java.lang.String" mandatory="true" defaultValue="application/octet-stream"/>

    <!-- === Page 3 — Destination === -->
    <input name="parentFolderId" type="java.lang.String" mandatory="false"/>
    <input name="description" type="java.lang.String" mandatory="false"/>

    <!-- === Page 4 — Advanced === -->
    <input name="uploadStrategy" type="java.lang.String" mandatory="false" defaultValue="AUTO"/>

    <!-- === Outputs === -->
    <output name="fileId" type="java.lang.String"/>
    <output name="fileWebViewLink" type="java.lang.String"/>
    <output name="fileWebContentLink" type="java.lang.String"/>
    <output name="success" type="java.lang.Boolean"/>
    <output name="errorMessage" type="java.lang.String"/>

    <!-- === Pages === -->
    <page id="connectionPage">
        <widget id="serviceAccountKeyJson" inputName="serviceAccountKeyJson" xsi:type="definition:Password"/>
        <widget id="impersonatedUserEmail" inputName="impersonatedUserEmail" xsi:type="definition:Text"/>
        <widget id="applicationNameWidget" inputName="applicationName" xsi:type="definition:Text"/>
        <widget id="connectTimeout" inputName="connectTimeout" xsi:type="definition:Text"/>
        <widget id="readTimeout" inputName="readTimeout" xsi:type="definition:Text"/>
    </page>

    <page id="uploadPage">
        <widget id="fileName" inputName="fileName" xsi:type="definition:Text"/>
        <widget id="fileContentBase64" inputName="fileContentBase64" xsi:type="definition:TextArea"/>
        <widget id="mimeType" inputName="mimeType" xsi:type="definition:Text"/>
    </page>

    <page id="destinationPage">
        <widget id="parentFolderId" inputName="parentFolderId" xsi:type="definition:Text"/>
        <widget id="description" inputName="description" xsi:type="definition:Text"/>
    </page>

    <page id="advancedPage">
        <widget id="uploadStrategy" inputName="uploadStrategy" xsi:type="definition:RadioGroup"/>
    </page>

</definition:ConnectorDefinition>
